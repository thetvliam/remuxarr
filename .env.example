# Copy to .env and adjust as needed.
# All variables use the REMUXARR_ prefix.
#
# Every value below already matches the app's own built-in default — an
# untouched .env, with nothing uncommented, works completely fine. This
# file is only for the handful of cases you actually want to override.
#
# Note: worker concurrency (max concurrent jobs) is NOT set here — it's
# a runtime setting, changeable from Settings > Worker in the web UI
# itself, not an environment variable.

REMUXARR_DATABASE_PATH=/config/remuxarr.db
REMUXARR_DEBUG=false

REMUXARR_FFMPEG_PATH=ffmpeg
REMUXARR_FFPROBE_PATH=ffprobe

# Seconds to wait after the last webhook for a given file before queuing it.
# Increase for very large season packs on slow disks.
REMUXARR_WEBHOOK_DEBOUNCE_SECONDS=10

REMUXARR_TEMP_DIR=/tmp/remuxarr
